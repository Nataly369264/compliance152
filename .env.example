# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Database
DB_PATH=data/compliance.db

# Scanner
MAX_PAGES=100
SCAN_TIMEOUT=30
CRAWL_DELAY=1.0

# Web Search (for legal verification)
# Backend: tavily | yandex | duckduckgo (default: duckduckgo — free, no API key)
SEARCH_BACKEND=duckduckgo
# Tavily API (optional, best for LLM — https://tavily.com)
TAVILY_API_KEY=
# Yandex XML (optional, best for Russian content — https://xml.yandex.ru)
YANDEX_XML_USER=
YANDEX_XML_KEY=
# Cache TTL for web verification results (hours)
WEB_CONTEXT_CACHE_TTL_HOURS=24

# Yandex Vision OCR (for PDF policies without ToUnicode mapping — see DEC-004)
# Required only for OCR of scanned PDF privacy policies.
# Get from Yandex Cloud console: IAM service account with role ai.vision.user
YANDEX_VISION_API_KEY=
YANDEX_FOLDER_ID=

# Logging
LOG_LEVEL=INFO

# Competitor Intelligence Monitor
# Antibot delays between requests (seconds)
COMPETITOR_MIN_DELAY=3.0
COMPETITOR_MAX_DELAY=8.0
COMPETITOR_FETCH_TIMEOUT=25

# Telegram notifications (required for alerts and digests)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
